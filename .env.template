# ─── MEDVERIFY ENVIRONMENT CONFIG ───

# Set to True only for development/demo without fine-tuned weights
MEDVERIFY_DEMO_MODE=True

# ─── API CONFIG ───
VITE_API_URL=http://localhost:8000
PORT=8000

# ─── LLM (OLLAMA) CONFIG ───
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral:latest

# ─── STORAGE PATHS (Absolute paths recommended for production) ───
# Defaults are relative to backend/
SQLITE_DB_PATH=data/medverify.db
UPLOADS_DIR_PATH=uploads
LOGS_DIR_PATH=logs
REPORTS_DIR_PATH=reports

# ─── SAFETY POLICY ───
OCR_LOW_CONFIDENCE_THRESHOLD=0.30
VISION_WEIGHT=0.65
OCR_WEIGHT=0.35

# ─── RATE LIMITING ───
DEFAULT_RATE_LIMIT=100/minute
